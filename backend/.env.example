# DeepSeek 免费大模型（OpenAI 兼容）
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=your-deepseek-api-key
LLM_MODEL=deepseek-chat
LLM_TIMEOUT=90

# 登录与会话
JWT_SECRET=change-me-in-production
SESSION_TTL_HOURS=24
SUPER_ADMIN_EMAIL=yangyuefang@guazi.com
SUPER_ADMIN_PASSWORD=your-super-admin-password

# Doris 连接（登录验证 + SQL 执行）
DORIS_HOST=doris-adhoc.dns.guazi.com
DORIS_PORT=9030
DORIS_DATABASE=hive.mysql
# 超级管理员备用 Doris 账号（可选）
ONLINE_DASHBOARD_DORIS_USER=
ONLINE_DASHBOARD_DORIS_PASSWORD=

# SQL 执行限制
SQL_EXECUTE_MAX_ROWS=1000
SQL_EXECUTE_TIMEOUT=120

# 关闭本地 sqls/ 目录自动同步（V3 改为用户手动导入）
AUTO_SYNC_SQL=false

# 数据持久化（云托管必配其一，否则重启/重新部署后 SQL 会丢失）
# 方案 A：挂载 COS/CFS 到容器 /app/data（推荐先用云开发对象存储）
# DATA_DIR=/app/data
# 方案 B：使用 MySQL（多实例更安全）
# DATABASE_URL=mysql+pymysql://user:password@host:3306/sql_agent?charset=utf8mb4

# 方案 C：自动备份 SQLite 到云开发对象存储（无需控制台「存储挂载」）
# COS_DB_BACKUP=true
# COS_BUCKET=797a-yzmty-d5gqs0ufzac842072-1325615965
# COS_REGION=ap-shanghai
# 若容器内无法自动获取临时密钥，再补充：
# COS_SECRET_ID=your-secret-id
# COS_SECRET_KEY=your-secret-key

# Agent 检索参数（可选）
AGENT_CANDIDATE_TOP_K=15
AGENT_RESULT_TOP_N=5

# 向量 / 语义检索（Phase 1+，默认 SQLite vector_chunks 表）
# VECTOR_STORE_TYPE=sqlite
# EMBEDDING_PROVIDER=fastembed
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_USE_FASTEMBED_FALLBACK=true
# INDEXING_WORKER_ENABLED=true
# COS_BACKUP_INTERVAL_SEC=45
